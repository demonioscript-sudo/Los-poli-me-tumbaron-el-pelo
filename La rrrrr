-- ==================== ANTI-DETECTION LAYER ====================
local AntiDetection = {}

-- Hook básico de Namecall (anti-check común)
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    -- Bloquea algunos checks comunes de anti-cheat
    if method == "FireServer" then
        if args[1] and typeof(args[1]) == "string" then
            local arg1 = string.lower(args[1])
            if arg1:find("ban") or arg1:find("kick") or arg1:find("report") or arg1:find("detect") then
                return wait(9e9) -- Silent drop
            end
        end
    end
    
    -- Anti teleport detection (hace el CFrame más "natural")
    if method == "SetPrimaryPartCFrame" or method == "LoadCharacter" then
        if AntiDetection.IsTeleporting then
            task.wait(math.random(15,35)/1000) -- micro delay humanizado
        end
    end
    
    return oldNamecall(self, ...)
end)

setreadonly(mt, true)

-- Anti idle kick + heartbeat spoof
AntiDetection.AntiAFK = function()
    task.spawn(function()
        while task.wait(math.random(30,60)) do
            pcall(function()
                game:GetService("VirtualUser"):Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                task.wait(0.1)
                game:GetService("VirtualUser"):Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            end)
        end
    end)
end

AntiDetection.AntiAFK()

