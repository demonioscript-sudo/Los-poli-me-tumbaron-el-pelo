            local character = player.Character or player.CharacterAdded:Wait()
            local humanoid = character:FindFirstChild("Humanoid")
            local rootpart = character:FindFirstChild("HumanoidRootPart")
            
            if not (humanoid and rootpart) then return end
            
            if humanoid.SeatPart then
                AntiDetection.IsTeleporting = true
                
                -- Teleport más humano (con tween-like random)
                local targetCFrame = CFrame.new(pos + Vector3.new(0, 5 + math.random(1,3), 0))
                
                task.spawn(function()
                    for i = 1, math.random(3,6) do
                        rootpart.CFrame = rootpart.CFrame:Lerp(targetCFrame, i/math.random(4,8))
                        task.wait(math.random(5,12)/100)
                    end
                    rootpart.CFrame = targetCFrame
                    AntiDetection.IsTeleporting = false
                end)
                
                Rayfield:Notify({
                    Title = "Teletransportado",
                    Content = "✅ " .. name .. " (Stealth)",
                    Duration = 2.5,
                    Image = 4483362458
